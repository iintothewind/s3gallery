{
  "Version": "2012-10-17",
  "Id": "PolicyForDestinationBucket",
  "Statement": [
    {
      "Sid": "AdminAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::<ACCOUNT_ID>:role/<ADMIN_OR_REPLICATION_ROLE>"
      },
      "Action": [
        "s3:GetBucketVersioning",
        "s3:GetObjectAcl",
        "s3:GetObject",
        "s3:ReplicateObject",
        "s3:ReplicateDelete",
        "s3:PutObjectAcl",
        "s3:PutObjectVersionAcl",
        "s3:PutBucketVersioning",
        "s3:ObjectOwnerOverrideToBucketOwner",
        "s3:DeleteObject",
        "s3:Put*",
        "s3:List*"
      ],
      "Resource": [
        "arn:aws:s3:::<BUCKET_NAME>",
        "arn:aws:s3:::<BUCKET_NAME>/*"
      ]
    },
    {
      "Sid": "PublicReadAppShell",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::<BUCKET_NAME>/<APP_PREFIX>/*"
      ]
    },
    {
      "Sid": "PublicListGalleryPrefix",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::<BUCKET_NAME>",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "<GALLERY_ROOT_PREFIX>/",
            "<GALLERY_ROOT_PREFIX>/*"
          ]
        }
      }
    },
    {
      "Sid": "PublicReadGalleryObjects",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::<BUCKET_NAME>/<GALLERY_ROOT_PREFIX>/*"
    }
  ]
}

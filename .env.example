S3GALLERY_BUCKET_NAME=my-bucket-name
S3GALLERY_REGION=us-east-1

# Where dist/ is deployed inside the bucket. No leading or trailing slash.
S3GALLERY_APP_PREFIX=nexus/gallery

# Image folder browsed by the gallery. No leading slash; trailing slash optional.
S3GALLERY_ROOT_PREFIX=nexus/content/vol-97

S3GALLERY_TITLE=S3Gallery
S3GALLERY_IMAGEKIT_ENDPOINT=

# Optional admin / replication role used by bucket_policy.local.json.
S3GALLERY_ADMIN_ACCOUNT_ID=
S3GALLERY_ADMIN_ROLE_NAME=
# Or set the full principal directly:
# S3GALLERY_ADMIN_PRINCIPAL=arn:aws:iam::123456789012:role/my-role
